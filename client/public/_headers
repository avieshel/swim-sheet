# Cache static assets aggressively (hashed filenames = immutable)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Icons and favicon — rarely change
/icons/*
  Cache-Control: public, max-age=31536000, immutable
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

# HTML must not be cached — always check for new SW version
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Root — SPA entry point, never cache
/
  Cache-Control: no-cache, no-store, must-revalidate

# Service worker — must always be fresh
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
/workbox-*.js
  Cache-Control: no-cache, no-store, must-revalidate

# PWA manifest
/manifest.webmanifest
  Cache-Control: public, max-age=3600

# Security headers — applied to all paths
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin